# ─────────────────────────────────────────────
# TxSurveillanceWatch — environment variables
# Copy this to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────

# ── Alert channels (leave blank to disable) ──────────────────────────────────
# Discord: Server → Channel Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# Bluesky: create account at bsky.app, then Settings → App Passwords
BLUESKY_HANDLE=txsurveillancewatch.bsky.social
BLUESKY_APP_PASSWORD=

# ── Paths ─────────────────────────────────────────────────────────────────────
DB_PATH=watchdog.db
RSS_OUTPUT_PATH=public/feed.xml
LOG_PATH=watchdog.log

# ── Public site URL (used in RSS feed link) ───────────────────────────────────
SITE_LINK=https://YOUR_GITHUB_HANDLE.github.io/tx-surveillance-watch

# ── Scraper settings ──────────────────────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=12
REQUEST_DELAY=2.0
USASPENDING_LOOKBACK_DAYS=90

# ── Enable/disable individual scrapers (set to 0 to skip) ────────────────────
ENABLE_USASPENDING=1
ENABLE_COSA=1
ENABLE_ESBD=1
ENABLE_BEXAR=1
